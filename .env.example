# Database
POSTGRES_DB=mtg
POSTGRES_USER=mtg
POSTGRES_PASSWORD=changeme

# Traefik hostnames
UI_HOST=edh.cardtrak.app
API_HOST=edh-api.cardtrak.app
JUPYTER_HOST=edh-nb.cardtrak.app

# Jupyter
JUPYTER_TOKEN=changeme

# Ingest
SCRYFALL_BULK_TYPE=oracle_cards
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
INGEST_BATCH_SIZE=256

# Training
WANDB_API_KEY=
WANDB_PROJECT=edh-builder
# Leave blank to use all GPUs; set to "0,1" etc. to pin
CUDA_VISIBLE_DEVICES=

# Logging
LOG_LEVEL=info
