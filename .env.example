# Database
POSTGRES_DB=mtg
POSTGRES_USER=mtg
POSTGRES_PASSWORD=changeme

# Traefik hostnames
UI_HOST=edh.cardtrak.app
API_HOST=edh-api.cardtrak.app
JUPYTER_HOST=edh-nb.cardtrak.app

# Jupyter
JUPYTER_TOKEN=changeme

# Ingest
SCRYFALL_BULK_TYPE=oracle_cards
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
INGEST_BATCH_SIZE=256

# HuggingFace Hub (get token at https://huggingface.co/settings/tokens)
HF_TOKEN=

# Training
WANDB_API_KEY=
WANDB_PROJECT=edh-builder
# Leave blank to use all GPUs; set to "0,1" etc. to pin
CUDA_VISIBLE_DEVICES=


# Admin (checkpoint upload endpoint — leave blank to disable auth)
ADMIN_TOKEN=changeme

# External API URL shown in the UI's Training Data tab (for the GPU machine's download link).
# Defaults to https://$API_HOST if not set.
EXTERNAL_API_URL=https://edh-api.cardtrak.app

# Logging
LOG_LEVEL=info
